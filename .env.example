# ============================================================
# .env.example — Copy to .env.local and fill in your values.
# NEVER commit .env.local or any file containing real secrets.
# ============================================================

# ── Supabase ────────────────────────────────────────────────
# Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_JWT_SECRET=your_supabase_jwt_secret

# MCP: Dashboard → Account → Access Tokens
SUPABASE_ACCESS_TOKEN=your_supabase_access_token
# MCP: Dashboard → Settings → General
SUPABASE_PROJECT_REF=your_project_ref

# ── Database (direct connection) ────────────────────────────
# Dashboard → Settings → Database → Connection string (URI mode)
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# ── Vercel ──────────────────────────────────────────────────
# vercel.com/account/tokens
VERCEL_TOKEN=your_vercel_token
# vercel.com → Project Settings → General
VERCEL_PROJECT_ID=your_vercel_project_id
VERCEL_ORG_ID=your_vercel_org_id

# ── Railway ─────────────────────────────────────────────────
# railway.app/account/tokens
RAILWAY_API_TOKEN=your_railway_api_token

# ── Resend ──────────────────────────────────────────────────
# resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key
# The from-address you've verified in Resend
RESEND_FROM_EMAIL=alerts@your-domain.com

# ── GitHub ──────────────────────────────────────────────────
# github.com/settings/tokens — scopes: repo, read:org
GITHUB_TOKEN=ghp_your_github_token

# ── Dodo Payments ───────────────────────────────────────────
# app.dodopayments.com → Developers → API Keys
DODO_API_KEY=your_dodo_api_key
DODO_WEBHOOK_SECRET=your_dodo_webhook_secret

# ── DeepSeek ────────────────────────────────────────────────
# platform.deepseek.com → API Keys
DEEPSEEK_API_KEY=sk_your_deepseek_api_key

# ── App ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ── Encryption ──────────────────────────────────────────────
# Random 32-byte hex string (use `openssl rand -hex 32` to generate)
ENCRYPTION_KEY=your_32_byte_hex_encryption_key

# ── Push Notifications (Web Push API) ───────────────────────
# Generate with: npm install -g web-push && web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_SUBJECT=mailto:your-email@example.com
