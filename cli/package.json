{
  "name": "@llm-atlas/cli",
  "version": "0.1.6",
  "description": "Auto-generate and maintain a raw knowledge layer for LLMs",
  "keywords": [
    "llm",
    "ai",
    "knowledge",
    "codebase",
    "context",
    "claude",
    "opencode"
  ],
  "author": "LLMAtlas",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/acrticsludge/LLMAtlas.git"
  },
  "bugs": {
    "url": "https://github.com/acrticsludge/LLMAtlas/issues"
  },
  "homepage": "https://github.com/acrticsludge/LLMAtlas#readme",
  "bin": {
    "llm-atlas": "./bin/llm-atlas.js"
  },
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "files": [
    "bin/",
    "dist/"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm test",
    "release": "node scripts/release.mjs"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "ignore": "^5.3.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0",
    "vitest": "^1.6.0"
  }
}
